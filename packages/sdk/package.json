{
  "name": "@campus-copilot/sdk",
  "version": "0.1.0",
  "private": false,
  "description": "Read-only SDK for Campus Copilot local BFF and imported workspace snapshots.",
  "license": "MIT",
  "keywords": ["campus-copilot", "sdk", "local-first", "read-only", "snapshot"],
  "homepage": "https://github.com/xiaojiou176-open/OpenCampus/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/OpenCampus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/OpenCampus.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["README.md", "dist"],
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js",
    "./snapshot": "./dist/snapshot.js",
    "./sites": "./dist/sites.js"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec esbuild ./src/index.ts ./src/api.ts ./src/snapshot.ts ./src/sites.ts --bundle --platform=node --format=esm --target=node20 --legal-comments=none --outdir=dist",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@campus-copilot/ai": "workspace:*",
    "@campus-copilot/exporter": "workspace:*",
    "@campus-copilot/schema": "workspace:*",
    "@campus-copilot/storage": "workspace:*",
    "esbuild": "^0.28.0",
    "zod": "^4.1.5"
  }
}
