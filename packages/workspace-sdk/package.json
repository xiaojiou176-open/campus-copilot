{
  "name": "@campus-copilot/workspace-sdk",
  "version": "0.1.0",
  "private": false,
  "description": "Read-only workspace derivation helpers for Campus Copilot imported snapshots.",
  "license": "MIT",
  "keywords": ["campus-copilot", "workspace-sdk", "local-first", "read-only", "snapshot"],
  "homepage": "https://github.com/xiaojiou176-open/OpenCampus/tree/main/packages/workspace-sdk",
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/OpenCampus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/OpenCampus.git",
    "directory": "packages/workspace-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["README.md", "dist"],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec esbuild ./src/index.ts --bundle --platform=node --format=esm --target=node20 --legal-comments=none --outfile=dist/index.js",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@campus-copilot/ai": "workspace:*",
    "@campus-copilot/exporter": "workspace:*",
    "@campus-copilot/schema": "workspace:*",
    "@campus-copilot/storage": "workspace:*",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.1.0"
  }
}
