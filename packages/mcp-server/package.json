{
  "name": "@campus-copilot/mcp-server",
  "version": "0.1.1",
  "private": false,
  "description": "Unified read-only MCP stdio server for Campus Copilot builder workflows.",
  "license": "MIT",
  "keywords": [
    "campus-copilot",
    "mcp",
    "server",
    "read-only",
    "stdio"
  ],
  "homepage": "https://github.com/xiaojiou176-open/OpenCampus/tree/main/packages/mcp-server",
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/OpenCampus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/OpenCampus.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.xiaojiou176-open/campus-copilot-mcp",
  "type": "module",
  "files": [
    "README.md",
    "dist"
  ],
  "bin": {
    "campus-copilot-mcp": "./dist/bin.mjs"
  },
  "scripts": {
    "build": "pnpm exec esbuild ./src/bin.ts ./src/server.ts --bundle --platform=node --format=esm --target=node20 --legal-comments=none --banner:js='#!/usr/bin/env node' --outdir=dist --out-extension:.js=.mjs",
    "pretest": "node ../../scripts/ensure-sdk-dist.mjs && pnpm build",
    "prepack": "pnpm build",
    "start": "pnpm build && node ./dist/bin.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test ./src/server.test.mjs ./src/bin.test.mjs"
  },
  "devDependencies": {
    "@campus-copilot/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "esbuild": "^0.28.0",
    "zod": "^4.4.3"
  }
}
