{
  "name": "@opencampus/mcp-readonly",
  "version": "0.1.0",
  "private": false,
  "description": "Read-only site-scoped MCP sidecars for OpenCampus snapshots.",
  "license": "MIT",
  "keywords": ["opencampus", "mcp", "read-only", "sidecar", "snapshot"],
  "homepage": "https://github.com/xiaojiou176-open/OpenCampus/tree/main/packages/mcp-readonly",
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/OpenCampus/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/OpenCampus.git",
    "directory": "packages/mcp-readonly"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["README.md", "dist"],
  "bin": {
    "opencampus-mcp-canvas": "./dist/canvas.js",
    "opencampus-mcp-gradescope": "./dist/gradescope.js",
    "opencampus-mcp-edstem": "./dist/edstem.js",
    "opencampus-mcp-myuw": "./dist/myuw.js"
  },
  "scripts": {
    "build": "pnpm exec esbuild ./bin/canvas.mjs ./bin/gradescope.mjs ./bin/edstem.mjs ./bin/myuw.mjs --bundle --platform=node --format=esm --target=node20 --legal-comments=none --banner:js='#!/usr/bin/env node' --outdir=dist",
    "prepack": "pnpm build",
    "start:canvas": "pnpm build && node ./dist/canvas.js",
    "start:gradescope": "pnpm build && node ./dist/gradescope.js",
    "start:edstem": "pnpm build && node ./dist/edstem.js",
    "start:myuw": "pnpm build && node ./dist/myuw.js",
    "test": "node --test ./src/server.test.mjs ./src/bin.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
