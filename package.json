{
  "name": "campus-copilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Source-first public monorepo for Campus Copilot, the flagship local-first academic decision workspace inside the OpenCampus family.",
  "license": "MIT",
  "homepage": "https://xiaojiou176-open.github.io/OpenCampus/",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/OpenCampus.git"
  },
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/OpenCampus/issues"
  },
  "keywords": [
    "campus-copilot",
    "campus",
    "canvas",
    "gradescope",
    "edstem",
    "myuw",
    "local-first",
    "academic-workspace",
    "source-first-monorepo",
    "browser-extension",
    "student-productivity",
    "read-only-mcp",
    "codex",
    "claude-code"
  ],
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "audit:disk": "node scripts/audit-disk.mjs",
    "audit:public-distribution": "node scripts/audit-public-distribution.mjs",
    "build:skill-catalog": "node scripts/check-skill-catalog.mjs --write",
    "render:social-preview": "bash scripts/render-social-preview.sh",
    "check:pnpm-store-health": "node scripts/check-pnpm-store-health.mjs",
    "hooks:install": "bash scripts/install-hooks.sh",
    "hooks:run:pre-commit": "bash scripts/run-pre-commit-hooks.sh",
    "hooks:run:pre-push": "bash scripts/run-pre-push-hooks.sh",
    "scan:git-history:secrets": "bash scripts/scan-git-history-secrets.sh",
    "check:secret-leaks": "bash scripts/check-secret-leaks.sh",
    "check:skill-catalog": "node scripts/check-skill-catalog.mjs",
    "check:mcp-registry-preflight": "node scripts/check-mcp-registry-preflight.mjs",
    "check:skill-publication-surface": "node scripts/check-skill-publication-surface.mjs",
    "check:container-surface": "node scripts/check-container-surface.mjs",
    "check:container-publication-surface": "node scripts/check-container-publication-surface.mjs",
    "dev:extension": "pnpm --filter @campus-copilot/extension dev",
    "dev:api": "pnpm --filter @campus-copilot/api dev",
    "start:api": "pnpm --filter @campus-copilot/api start",
    "start:mcp": "pnpm --filter @campus-copilot/mcp-server start",
    "cli:health": "pnpm --filter @campus-copilot/cli start -- health",
    "build:extension": "pnpm --filter @campus-copilot/extension build",
    "test:extension": "pnpm --filter @campus-copilot/extension test",
    "test:smoke": "pnpm --filter @campus-copilot/extension test:smoke",
    "test:api": "pnpm --filter @campus-copilot/api test",
    "smoke:api": "bash scripts/api-healthcheck.sh",
    "smoke:docker:api": "bash scripts/docker-api-smoke.sh",
    "smoke:provider": "bash scripts/provider-roundtrip-smoke.sh",
    "smoke:sidepanel": "node scripts/run-node-with-env.mjs scripts/sidepanel-provider-smoke.mjs",
    "smoke:support": "bash scripts/support-bundle-smoke.sh",
    "browser:bootstrap": "node scripts/run-node-with-env.mjs scripts/bootstrap-browser-root.mjs",
    "browser:bootstrap:apply": "node scripts/run-node-with-env.mjs scripts/bootstrap-browser-root.mjs --apply",
    "browser:launch": "node scripts/run-node-with-env.mjs scripts/browser-launch.mjs",
    "browser:attach-check": "node scripts/run-node-with-env.mjs scripts/browser-attach-check.mjs",
    "test:repo": "node --test scripts/live-probe-shared.test.mjs scripts/browser-evidence-utils.test.mjs scripts/browser-evidence-capture.test.mjs scripts/browser-instance-identity.test.mjs scripts/browser-launch.test.mjs scripts/disk-governance.test.mjs scripts/browser-root-contract.test.mjs scripts/bootstrap-browser-root.test.mjs scripts/consumer-surfaces.test.mjs scripts/check-container-surface.test.mjs scripts/check-public-surface.test.mjs scripts/check-skill-catalog.test.mjs scripts/public-package-surface.test.mjs scripts/test-coverage.test.mjs scripts/dependency-security.test.mjs scripts/cache-governance-race.test.mjs scripts/redact-live-adapter-fixture.test.mjs scripts/check-sensitive-surface.test.mjs scripts/check-sensitive-history.test.mjs scripts/run-node-with-env.test.mjs",
    "test:workspaces": "pnpm -r --filter @campus-copilot/* --if-present test",
    "test:coverage": "node scripts/test-coverage.mjs",
    "cleanup:repo:safe": "bash scripts/cleanup-repo-safe.sh",
    "cleanup:runtime": "bash scripts/cleanup-runtime.sh",
    "cleanup:runtime:closeout": "CAMPUS_COPILOT_RUNTIME_CLEAN_LEVEL=closeout bash scripts/cleanup-runtime.sh",
    "preflight:live": "node scripts/run-node-with-env.mjs scripts/live-preflight.mjs",
    "diagnose:live": "pnpm cleanup:runtime && pnpm preflight:live",
    "support:bundle": "node scripts/run-node-with-env.mjs scripts/support-bundle.mjs",
    "capture:browser-evidence": "node scripts/run-node-with-env.mjs scripts/browser-evidence-capture.mjs",
    "probe:live": "node scripts/run-node-with-env.mjs scripts/live-site-probe.mjs",
    "redact:live-fixture": "node scripts/redact-live-adapter-fixture.mjs",
    "check:docs:ssot": "node scripts/check-docs-ssot.mjs",
    "check:consumer-surfaces": "node scripts/check-consumer-surfaces.mjs",
    "check:verification-claims": "node scripts/check-verification-claims.mjs",
    "check:campus-readonly-boundary": "node scripts/check-campus-readonly-boundary.mjs",
    "check:public-surface": "node scripts/check-public-surface.mjs",
    "proof:public": "node scripts/public-distribution-proof.mjs",
    "check:actions-pinning": "node scripts/check-actions-pinning.mjs",
    "check:english-canonical": "node scripts/check-english-canonical.mjs",
    "check:logging-schema": "node scripts/check-logging-schema.mjs",
    "check:host-safety": "node scripts/check-host-safety-contract.mjs",
    "check:sensitive-surface": "node scripts/check-sensitive-surface.mjs",
    "check:sensitive-history": "node scripts/check-sensitive-history.mjs",
    "check:runtime-artifacts": "node scripts/check-runtime-artifacts.mjs",
    "check:root-hygiene": "node scripts/check-root-hygiene.mjs",
    "verify:governance": "node scripts/check-docs-ssot.mjs && node scripts/check-consumer-surfaces.mjs && node scripts/check-verification-claims.mjs && node scripts/check-campus-readonly-boundary.mjs && node scripts/check-public-surface.mjs && node scripts/check-skill-catalog.mjs && node scripts/check-skill-publication-surface.mjs && node scripts/check-mcp-registry-preflight.mjs && node scripts/check-container-surface.mjs && node scripts/check-container-publication-surface.mjs && node scripts/check-actions-pinning.mjs && node scripts/check-english-canonical.mjs && node scripts/check-logging-schema.mjs && node scripts/check-host-safety-contract.mjs && node scripts/check-sensitive-surface.mjs && node scripts/check-sensitive-history.mjs && node scripts/check-runtime-artifacts.mjs && node scripts/check-root-hygiene.mjs",
    "verify": "bash scripts/verify.sh",
    "verify:hosted": "bash scripts/verify-hosted.sh",
    "verify:nightly": "bash scripts/verify-nightly.sh",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm test:workspaces && pnpm test:repo"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^4.1.4",
    "fake-indexeddb": "^6.1.0",
    "msw": "^2.13.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "defu": "^6.1.6",
      "hono": "^4.12.14",
      "web-ext-run@0.2.4>multimatch": "^8.0.0"
    }
  }
}
