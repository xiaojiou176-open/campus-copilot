{
  "mcpServers": {
    "campus-copilot-canvas": {
      "command": "campus-copilot-mcp-canvas",
      "env": {
        "CAMPUS_COPILOT_SNAPSHOT": "/absolute/path/to/workspace-snapshot.json"
      }
    },
    "campus-copilot-edstem": {
      "command": "campus-copilot-mcp-edstem",
      "env": {
        "CAMPUS_COPILOT_SNAPSHOT": "/absolute/path/to/workspace-snapshot.json"
      }
    }
  }
}
