{
  "mcpServers": {
    "opencampus-gradescope": {
      "command": "bash",
      "args": [
        "/absolute/path/to/opencampus/scripts/consumer/opencampus-site-sidecar.sh",
        "gradescope"
      ],
      "env": {
        "CAMPUS_COPILOT_SNAPSHOT": "/absolute/path/to/workspace-snapshot.json"
      }
    },
    "opencampus-myuw": {
      "command": "bash",
      "args": [
        "/absolute/path/to/opencampus/scripts/consumer/opencampus-site-sidecar.sh",
        "myuw"
      ],
      "env": {
        "CAMPUS_COPILOT_SNAPSHOT": "/absolute/path/to/workspace-snapshot.json"
      }
    }
  }
}
