# Campus Copilot BFF
# Default local listen port
PORT=8787

# Formal provider path
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: override the provider API base URL for a debugging proxy or local gateway
OPENAI_BASE_URL=
GEMINI_BASE_URL=

# Optional: local Switchyard runtime bridge for service-first integration.
# Example: http://127.0.0.1:4010
SWITCHYARD_BASE_URL=
SWITCHYARD_AUTH_TOKEN=

# Optional: repo-owned browser root and single-instance attach contract.
# The canonical live/browser root is:
#   ${XDG_CACHE_HOME:-$HOME/.cache}/campus-copilot/browser/chrome-user-data
# The canonical repo profile is:
#   Profile 1  (display name: campus-copilot)
# The legacy source profile remains:
#   source root = $HOME/Library/Application Support/Google/Chrome
#   source profile = Profile 13
CHROME_CDP_URL=
CHROME_USER_DATA_DIR="$HOME/.cache/campus-copilot/browser/chrome-user-data"
CHROME_PROFILE_NAME=Profile 1
CHROME_ATTACH_MODE=page

# Optional: source Chrome root/profile for one-time bootstrap.
CAMPUS_COPILOT_SOURCE_CHROME_ROOT="$HOME/Library/Application Support/Google/Chrome"
CAMPUS_COPILOT_SOURCE_PROFILE_DIRECTORY=Profile 13

# Optional: repo-owned browser state.
CAMPUS_COPILOT_BROWSER_ROOT="$HOME/.cache/campus-copilot/browser/chrome-user-data"
CAMPUS_COPILOT_BROWSER_CDP_PORT=9334
CAMPUS_COPILOT_BROWSER_PROFILE_DIRECTORY=Profile 1
CAMPUS_COPILOT_BROWSER_PROFILE_DISPLAY_NAME=campus-copilot
# Optional browser-window identity hints for the repo-owned browser lane.
# These control the generated local identity tab opened by `pnpm browser:launch`.
CAMPUS_COPILOT_BROWSER_IDENTITY_LABEL=
CAMPUS_COPILOT_BROWSER_IDENTITY_ACCENT=

# Optional: repo-exclusive external cache governance.
# Leave the root empty to use the default repo cache home:
#   ${XDG_CACHE_HOME:-$HOME/.cache}/campus-copilot
# Repo-owned browser state lives under:
#   ${XDG_CACHE_HOME:-$HOME/.cache}/campus-copilot/browser/
# Generic external cache GC applies to:
#   ${XDG_CACHE_HOME:-$HOME/.cache}/campus-copilot/cache
# The browser subtree is permanent state and is excluded from TTL/cap cleanup.
CAMPUS_COPILOT_CACHE_HOME=
CAMPUS_COPILOT_MANAGED_EXTERNAL_CACHE_ROOT=
CAMPUS_COPILOT_CACHE_TTL_HOURS=168
CAMPUS_COPILOT_CACHE_MAX_MB=2048
