    {
      "id": "openclaw-readonly-consumer",
      "slug": "openclaw-readonly-consumer",
      "displayName": "Openclaw Readonly Consumer",
      "version": "0.1.0",
      "path": "skills/openclaw-readonly-consumer/SKILL.md",
      "tags": [
        "latest"
      ],
      "summary": "Guide an OpenClaw-style local runtime onto the snapshot-first or thin-BFF-first read-only CampusCopilot path."
    },
    {
      "id": "site-mcp-consumer",
      "slug": "site-mcp-consumer",
      "displayName": "Site Mcp Consumer",
      "version": "0.1.0",
