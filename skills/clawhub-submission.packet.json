{
  "schemaVersion": "1.0.0",
  "kind": "repo-owned-clawhub-skill-submission-packet",
  "truthBoundary": "This is a repo-owned submission packet that mirrors official ClawHub skill-publish inputs and OpenClaw bundle-detection facts. It is not an upstream marketplace manifest.",
  "officialSources": {
    "clawhub": "https://docs.openclaw.ai/tools/clawhub",
    "skills": "https://docs.openclaw.ai/tools/skills",
    "bundles": "https://docs.openclaw.ai/plugins/bundles"
  },
  "pack": {
    "name": "campus-copilot-public-skills",
    "version": "0.1.0",
    "scope": "read-only",
    "sourceRoot": "skills",
    "bundleCompatibility": {
      "openclawBundleFormat": "manifestless-claude-layout",
      "detectedRoots": [
        "skills/"
      ],
      "nativeManifestIncluded": false
    }
  },
  "publishDefaults": {
    "changelogSource": "CHANGELOG.md",
    "defaultTags": [
      "latest"
    ]
  },
