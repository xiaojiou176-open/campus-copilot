      "tags": [
        "latest"
      ],
      "summary": "Summarize what is open, what changed, what is due soon, and which site is carrying the workload from a CampusCopilot snapshot."
    },
    {
      "id": "read-only-workspace-audit",
      "slug": "read-only-workspace-audit",
      "displayName": "Read Only Workspace Audit",
